{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gonorth-production-acd7.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://gonorth-production-acd7.up.railway.app/health"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://gonorth-production-acd7.up.railway.app/uploads/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
